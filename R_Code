## Rowcount audit //////////////////////////////////////////////////////////////
# //////////////////////////////////////////////////////////////////////////////

if (any(row_audit$n != row_audit$n[1])) {
  warning("Row count changed during processing. Review rowcount audit.")
}

write_xlsx(
  row_audit,
  sprintf("C:/Users/ad905068/OneDrive - BioMarin/Documents/R_for_BMRN/output/rowcount_audit_%s.xlsx", Sys.Date())
)

# Add check if Code Switches sheet is not blank.
if (nrow(di_MedDRA_Code_Switches) > 0) {
  warning("Code Switches sheet contains rows but is not processed.")
}

